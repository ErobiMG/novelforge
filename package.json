{
  "name": "novelforge",
  "version": "1.0.0",
  "description": "NovelForge AI - Immersive Story Writing Studio",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.novelforge.app",
    "productName": "NovelForge",
    "win": {
      "target": "portable"
    },
    "files": [
      "index.html",
      "app.js",
      "styles.css",
      "main.js"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
